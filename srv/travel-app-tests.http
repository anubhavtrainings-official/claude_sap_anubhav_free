### ============================================================
###  SECTION 8 — $BATCH (Bulk / Dependent Data Insert)
### ============================================================

### 8.1  Batch — Create 3 Destinations at once
POST {{catalog}}/$batch
Content-Type: application/json

{
  "requests": [
    {
      "id": "dest-1",
      "method": "POST",
      "url": "Destinations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "name": "Dubai Marina",
        "country": "UAE",
        "city": "Dubai",
        "region": "Dubai",
        "description": "Modern waterfront district."
      }
    },
    {
      "id": "dest-2",
      "method": "POST",
      "url": "Destinations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "name": "Singapore Orchard",
        "country": "Singapore",
        "city": "Singapore",
        "region": "Central",
        "description": "Premier shopping and business district."
      }
    },
    {
      "id": "dest-3",
      "method": "POST",
      "url": "Destinations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "name": "London Canary Wharf",
        "country": "United Kingdom",
        "city": "London",
        "region": "Greater London",
        "description": "Major business and financial district."
      }
    }
  ]
}

###

### 8.2  Batch — Create Traveller + 3 non-overlapping Locations
POST {{catalog}}/$batch
Content-Type: application/json

{
  "requests": [
    {
      "id": "t-1",
      "method": "POST",
      "url": "Travellers",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "firstName": "Carlos",
        "lastName": "Rivera",
        "email": "carlos.rivera@company.com",
        "phone": "+1-555-111-2222",
        "userID": "carlos.rivera@company.com",
        "type_code": "ST",
        "status_code": "A",
        "addressType_code": "H"
      }
    },
    {
      "id": "loc-1",
      "dependsOn": ["t-1"],
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "${{t-1.ID}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-01-05",
        "travelTo": "2025-01-12",
        "notes": "First trip — Dubai."
      }
    },
    {
      "id": "loc-2",
      "dependsOn": ["t-1"],
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "${{t-1.ID}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-02-10",
        "travelTo": "2025-02-17",
        "notes": "Second trip — Singapore."
      }
    },
    {
      "id": "loc-3",
      "dependsOn": ["t-1"],
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "${{t-1.ID}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-04-20",
        "travelTo": "2025-04-28",
        "notes": "Third trip — London."
      }
    }
  ]
}

###

### 8.3  Batch — Mixed valid and OVERLAPPING locations (expect 207)
# loc-A and loc-B are valid; loc-C overlaps loc-A → 409 for loc-C only
POST {{catalog}}/$batch
Content-Type: application/json

{
  "requests": [
    {
      "id": "loc-A",
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "{{travellerId}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-07-01",
        "travelTo": "2025-07-08",
        "notes": "Valid trip A."
      }
    },
    {
      "id": "loc-B",
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "{{travellerId}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-08-10",
        "travelTo": "2025-08-15",
        "notes": "Valid trip B."
      }
    },
    {
      "id": "loc-C",
      "method": "POST",
      "url": "TravelledLocations",
      "headers": { "Content-Type": "application/json" },
      "body": {
        "traveller_ID": "{{travellerId}}",
        "destination_ID": "{{destinationId}}",
        "travelFrom": "2025-07-05",
        "travelTo": "2025-07-12",
        "notes": "Overlaps trip A — expect 409 on this request only."
      }
    }
  ]
}

###

### 8.4  Batch — Batch read: multiple entities in one call
POST {{catalog}}/$batch
Content-Type: application/json

{
  "requests": [
    {
      "id": "r-1",
      "method": "GET",
      "url": "Travellers?$select=ID,firstName,lastName,fullName"
    },
    {
      "id": "r-2",
      "method": "GET",
      "url": "Destinations?$select=ID,name,country"
    },
    {
      "id": "r-3",
      "method": "GET",
      "url": "TravellerStatus"
    }
  ]
}

