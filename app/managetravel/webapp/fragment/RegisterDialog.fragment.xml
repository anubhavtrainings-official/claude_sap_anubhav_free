<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:f="sap.ui.layout.form">
    <Dialog id="registerDialog" title="Register as Traveller" contentWidth="26rem">
        <content>
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout"
                          labelSpanXL="12" labelSpanL="12" labelSpanM="12" labelSpanS="12"
                          columnsXL="1" columnsL="1" columnsM="1">
                <f:content>
                    <Label text="First Name" required="true"/>
                    <Input value="{reg>/firstName}"/>
                    <Label text="Last Name" required="true"/>
                    <Input value="{reg>/lastName}"/>
                    <Label text="Email" required="true"/>
                    <Input value="{reg>/email}" type="Email" placeholder="you@example.com"/>
                    <Label text="Password" required="true"/>
                    <Input value="{reg>/password}" type="Password" placeholder="Min. 8 characters"/>
                    <Label text="Phone"/>
                    <Input value="{reg>/phone}"/>
                    <Label text="Address Type"/>
                    <Select selectedKey="{reg>/addressType}"
                            items="{path: 'reg>/addressTypes', templateShareable: false}">
                        <core:Item key="{reg>code}" text="{reg>name}"/>
                    </Select>
                </f:content>
            </f:SimpleForm>
        </content>
        <beginButton>
            <Button text="Register" type="Emphasized" press=".onSubmitRegister"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onCancelRegister"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
