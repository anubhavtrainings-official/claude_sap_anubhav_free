<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Bar design="Header">
        <contentLeft>
            <Image src="https://s2.coinmarketcap.com/static/img/coins/200x200/37581.png"
                   width="2.5rem" height="2.5rem" class="sapUiTinyMarginEnd"/>
            <Title text="Anubhav Trainings — TravelHub" level="H2"/>
        </contentLeft>
        <contentRight>
            <Text text="{userModel>/fullName} ({userModel>/role})"
                  visible="{= !!${userModel>/loginName} }"
                  class="sapUiSmallMarginEnd"/>
            <Button icon="sap-icon://log" text="Logout"
                    press=".onLogout"
                    visible="{= !!${userModel>/loginName} }"/>
        </contentRight>
    </Bar>
</core:FragmentDefinition>
